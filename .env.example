# ── Airtable ──────────────────────────────────────────────
# Get your Personal Access Token from airtable.com/create/tokens
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX

# Find the Base ID in your Airtable URL: airtable.com/appXXXXXX/...
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Must match the exact table names you create in Airtable
AIRTABLE_LISTINGS_TABLE=Listings
AIRTABLE_ACTIVITY_TABLE=Activity

# ── Admin Auth ────────────────────────────────────────────
# The password your VA uses to log into /admin
ADMIN_PASSWORD=your-secure-password-here

# A random secret string used to sign the session cookie (make it long and random)
ADMIN_SECRET=some-very-long-random-string-change-this

# ── Agent Info (shown on all client dashboards) ───────────
AGENT_NAME=Will Aufhammer
AGENT_COMPANY=Aufhammer Homes
AGENT_PHONE=206.604.4992
AGENT_EMAIL=will.aufhammer@compass.com
# Optional: direct URL to a headshot image
AGENT_PHOTO_URL=

# ── App ───────────────────────────────────────────────────
# The live URL of your Vercel deployment (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
